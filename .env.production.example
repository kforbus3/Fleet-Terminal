# Fleet Terminal — PRODUCTION / internet-exposed configuration.
#
# Copy to .env and fill in. This profile assumes the app sits BEHIND a reverse
# proxy (Nginx Proxy Manager) that terminates TLS with a Let's Encrypt cert and
# forwards to the backend over the internal Docker network. Only port 443 of the
# proxy should be reachable from the internet — never publish 8080/5173/Postgres/
# Redis/jumphost/WireGuard. See docs/internet-exposure.md.

# --- Runtime ---
FLEET_ENV=production
FLEET_PUBLIC_URL=https://fleet.example.com   # MUST match the public HTTPS URL

# --- Secrets (generate: `openssl rand -hex 32`). Never commit real values. ---
FLEET_JWT_SECRET=
FLEET_CSRF_SECRET=
FLEET_CA_PASSPHRASE=
POSTGRES_PASSWORD=

# --- Cookies / TLS ---
# REQUIRED behind HTTPS: marks auth cookies Secure so they never leak over HTTP.
FLEET_COOKIE_SECURE=true

# --- Session lifetime (tighter than dev) ---
FLEET_SESSION_IDLE_TTL=15m
FLEET_SESSION_ABSOLUTE_TTL=8h
FLEET_REFRESH_TOKEN_TTL=168h        # 7 days (vs 30d default)
FLEET_USER_CERT_TTL=168h

# --- Per-IP rate limiting (bot/abuse defense). Tune to your user base. ---
FLEET_RATE_LIMIT_PER_MIN=600
FLEET_RATE_LIMIT_BURST=120
FLEET_AUTH_RATE_LIMIT_PER_MIN=15
FLEET_AUTH_RATE_LIMIT_BURST=8

# --- Bootstrap: disable once the first super admin exists. The endpoint also
# self-seals when any user is present, but set this to false as belt-and-braces.
FLEET_ALLOW_BOOTSTRAP=false

# --- WebAuthn / passkeys: RPID must be the registrable domain of PUBLIC_URL.
FLEET_WEBAUTHN_RPID=fleet.example.com
FLEET_WEBAUTHN_ORIGINS=https://fleet.example.com

# --- SSH gateway: pin jump-host key verification in production. ---
FLEET_JUMP_HOST=jumphost:22
FLEET_JUMP_USER=fleet
# FLEET_JUMP_KNOWN_HOSTS=/etc/fleet/known_hosts   # mount a known_hosts file

# --- WireGuard endpoint reachable by managed hosts (public IP/DNS + port). ---
FLEET_WG_JUMP_ENDPOINT=vpn.example.com:51820

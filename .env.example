# Fleet Terminal — environment configuration.
# Copy to .env and adjust. In production, set strong secrets and enable TLS/cookies.

# --- Runtime ---
FLEET_ENV=development
FLEET_VERSION=dev
FLEET_PUBLIC_URL=http://localhost:8080

# --- Database / cache ---
POSTGRES_PASSWORD=fleet

# --- Secrets (generate strong values for production: `openssl rand -hex 32`) ---
FLEET_JWT_SECRET=
FLEET_CSRF_SECRET=
FLEET_CA_PASSPHRASE=

# --- Cookies / TLS ---
# Set true only when serving over HTTPS.
FLEET_COOKIE_SECURE=false

# --- SSH gateway / jump host ---
FLEET_JUMP_HOST=jumphost:22
FLEET_JUMP_USER=fleet

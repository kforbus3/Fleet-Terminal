# Fleet Terminal — environment configuration.
# Copy to .env and adjust. In production, set strong secrets and enable TLS/cookies.

# --- Runtime ---
FLEET_ENV=development
FLEET_VERSION=dev
FLEET_PUBLIC_URL=http://localhost:8080

# --- Database / cache ---
POSTGRES_PASSWORD=fleet

# --- Secrets (generate strong values for production: `openssl rand -hex 32`) ---
FLEET_JWT_SECRET=
FLEET_CSRF_SECRET=
FLEET_CA_PASSPHRASE=

# --- Cookies / TLS ---
# Set true only when serving over HTTPS.
FLEET_COOKIE_SECURE=false

# --- Session lifetime ---
FLEET_SESSION_IDLE_TTL=30m       # end a session after this much inactivity
FLEET_SESSION_ABSOLUTE_TTL=12h   # hard cap on session age (0 = unlimited)
FLEET_USER_CERT_TTL=168h         # ephemeral SSH cert lifetime (7d), auto-renewed
# CA-key rotation reminder threshold: System Health flags the active SSH CA key
# for rotation once it is older than this. Default 365 days.
# FLEET_CA_ROTATE_AFTER=8760h
FLEET_REFRESH_TOKEN_TTL=720h     # refresh-cookie lifetime (30d); shorten for internet exposure (e.g. 168h)

# --- Per-IP rate limiting (0 disables). Defends against bots when exposed.
# Keys on the client IP via X-Forwarded-For — only trust this BEHIND a reverse
# proxy (e.g. Nginx Proxy Manager) that sets it; never expose the app directly.
FLEET_RATE_LIMIT_PER_MIN=600       # general API budget per IP
FLEET_RATE_LIMIT_BURST=120
FLEET_AUTH_RATE_LIMIT_PER_MIN=20   # stricter budget for /auth + /bootstrap per IP
FLEET_AUTH_RATE_LIMIT_BURST=10

# --- SSH gateway / jump host ---
FLEET_JUMP_HOST=jumphost:22
FLEET_JUMP_USER=fleet
# The gateway verifies SSH host keys trust-on-first-use by default (the first key
# seen for a host is pinned; a later mismatch is refused as a possible MITM).
# Only the local test fabric sets this to accept-any; it is refused in production.
# FLEET_SSH_INSECURE_HOST_KEYS=false

# --- Control-plane protection ---
# Comma-separated hostnames/addresses of Fleet's own control-plane host(s) — the
# machine(s) running the backend/jump host. Remediating one of these can lock
# Fleet out of the whole fleet (e.g. an ip_forward/rp_filter sysctl breaking the
# container/WireGuard networking that serves the UI), so it requires an extra
# confirmation. The jump host is detected automatically; hosts can also be marked
# with a "control-plane" or "protected" tag instead of listing them here.
# FLEET_CONTROL_PLANE_HOSTS=fleet-host,10.0.0.5

# --- SFTP ---
# Max upload size in bytes (0 = unlimited). Default 5 GiB.
FLEET_MAX_UPLOAD_BYTES=5368709120

# --- WireGuard overlay (host enrollment) ---
FLEET_WG_SUBNET=10.100.0.0/24
FLEET_WG_JUMP_IP=10.100.0.1
FLEET_WG_PORT=51820
# The address managed hosts use to reach the jump host (VPN server) over
# WireGuard. For REAL hosts this MUST be a publicly-routable IP/DNS name + port
# reachable from those hosts — NOT an internal Docker name like "jumphost".
# It can also be set/overridden per host in the enroll dialog.
FLEET_WG_JUMP_ENDPOINT=jumphost:51820

# --- Observability (OpenTelemetry tracing; disabled unless both are set) ---
FLEET_TRACING=false
FLEET_OTLP_ENDPOINT=

# --- WebAuthn / passkeys (defaults derive from FLEET_PUBLIC_URL) ---
# FLEET_WEBAUTHN_RPID=localhost
# FLEET_WEBAUTHN_ORIGINS=http://localhost:5173,http://localhost:8080

# --- Ansible playbooks ---
# Base URL of the ansible-runner sidecar that validates/lints (and later runs)
# playbooks. The compose stack starts this service automatically.
# FLEET_ANSIBLE_RUNNER_URL=http://ansible-runner:8000

# --- Encrypted backups ---
# Where scheduled/on-demand database backups are written (map this to off-host
# storage). FLEET_BACKUP_PASSPHRASE encrypts them (openssl AES-256); if empty it
# falls back to FLEET_CA_PASSPHRASE. Keep this passphrase OFF the server — it is
# NOT included in backups, by design. See docs/break-glass.md.
# FLEET_BACKUP_DIR=/var/lib/fleet/backups
# FLEET_BACKUP_PASSPHRASE=
